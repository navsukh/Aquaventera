# Aqua Vèntèra environment configuration
# Copy this file to .env and replace the placeholder values before running the app.

# -----------------------------
# Server / Runtime
# -----------------------------
# Port for the Express server.
PORT=3000

# Runtime environment. Use "development" locally and "production" in deployment.
NODE_ENV=development

# Public base URL for the app. Used for CORS and absolute links.
BASE_URL=http://localhost:3000

# -----------------------------
# PostgreSQL Database
# -----------------------------
# Primary PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aquaventera

# Optional fallback PostgreSQL settings if DATABASE_URL is not provided.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=aquaventera

# -----------------------------
# Supabase Storage
# -----------------------------
# Your Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key or anon key that can access the storage bucket.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional fallback if you prefer to use the anon key instead.
# SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Storage bucket name for uploaded files.
SUPABASE_BUCKET=uploads

# -----------------------------
# Sessions / Authentication
# -----------------------------
# Secret used to sign the admin JWT session token.
JWT_SECRET=change-this-to-a-long-random-secret

# JWT token lifetime.
JWT_EXPIRES_IN=8h

# Secret used by CSRF protection middleware.
CSRF_SECRET=change-this-to-another-long-random-secret

# -----------------------------
# Admin Bootstrap
# -----------------------------
# Optional initial admin account created or updated on startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# -----------------------------
# Security / Rate Limiting
# -----------------------------
# Maximum file upload size in megabytes.
UPLOAD_MAX_MB=10

# Rate limiting window in milliseconds.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# -----------------------------
# Email (Optional)
# -----------------------------
# SMTP settings used by the enquiry email flow.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
EMAIL_FROM=no-reply@example.com
EMAIL_TO=admin@example.com
