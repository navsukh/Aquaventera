# ── Server ─────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL=https://yourdomain.com

# ── Session ─────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ── JWT (Admin auth) ────────────────────────────────
JWT_SECRET=change_this_jwt_secret_too
JWT_EXPIRES_IN=8h

# ── Admin credentials ───────────────────────────────
ADMIN_EMAIL=admin@aquaverite.com
ADMIN_PASSWORD=ChangeThisPassword123!

# ── Email (SMTP) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Aqua Verite" <hello@aquaverite.com>
EMAIL_TO=enquiries@aquaverite.com

# ── File uploads ─────────────────────────────────────
UPLOAD_MAX_MB=10

# ── Rate limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
